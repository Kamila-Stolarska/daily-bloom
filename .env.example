# Klucz do Groq (Whisper transcription). Pobierz: https://console.groq.com/keys
# NIE commituj prawdziwego klucza. Skopiuj ten plik jako `.env.local`.
GROQ_API_KEY=

# Baza URL backendu transkrypcji. Pusto = relative (działa na webie pod tą samą domeną).
# Na natywne (iOS/Android) ustaw pełny URL preview/produkcji Vercela:
# EXPO_PUBLIC_API_BASE=https://daily-bloom.vercel.app
EXPO_PUBLIC_API_BASE=
